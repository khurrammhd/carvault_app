<?xml version="1.0" encoding="utf-8"?>
<!-- Native launch screen — shown instantly on app tap, before the Flutter
     engine has loaded. Matches the Flutter-level SplashScreen's colors
     (AppColors.background + the primaryContainer app-mark badge) exactly,
     so there's no flash of plain white before Flutter takes over. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#F8F4F1" />
        </shape>
    </item>
    <item
        android:width="76dp"
        android:height="76dp"
        android:gravity="center"
        android:drawable="@drawable/launch_badge" />
</layer-list>
